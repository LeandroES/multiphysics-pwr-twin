# PostgreSQL / TimescaleDB
POSTGRES_USER=pwr_user
POSTGRES_PASSWORD=pwr_secret
POSTGRES_DB=pwr_twin
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://pwr_user:pwr_secret@db:5432/pwr_twin

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
SECRET_KEY=change_me_in_production_use_a_long_random_string
